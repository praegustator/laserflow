{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "svg-pathdata": ["./node_modules/svg-pathdata/lib/SVGPathData"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
